<view class="container">
  <view class="card">
    <view class="title">员工注册申请</view>

    <view class="form-item">
      <text class="label">账号(工号)</text>
      <input class="input" placeholder="请输入账号/工号" value="{{form.username}}" bindinput="onInput" data-field="username" />
    </view>

    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
    </view>

    <view class="form-item">
      <text class="label">部门ID</text>
      <input class="input" placeholder="请输入部门ID(可选)" value="{{form.departmentId}}" bindinput="onInput" data-field="departmentId" />
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" placeholder="请输入密码" password="true" value="{{form.password}}" bindinput="onInput" data-field="password" />
    </view>

    <view class="form-item">
      <text class="label">确认密码</text>
      <input class="input" placeholder="请再次输入密码" password="true" value="{{confirmPassword}}" bindinput="onConfirmPassword" />
    </view>

    <button class="btn" bindtap="handleSubmit" loading="{{loading}}">提交注册申请</button>

    <view class="tips">提交后需管理员审核通过才能登录</view>
  </view>
</view>
