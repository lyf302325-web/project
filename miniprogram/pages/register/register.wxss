.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #333;
}

.form-item {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 22rpx 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.btn {
  margin-top: 20rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
}

.tips {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}
