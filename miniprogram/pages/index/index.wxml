<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar">{{userInfo.name ? userInfo.name[0] : '员'}}</view>
    <view class="user-info">
      <view class="user-name">{{userInfo.name || '员工'}}</view>
      <view class="user-dept">{{userInfo.departmentName || '未分配部门'}}</view>
    </view>
    <view class="today-date">{{todayDate}}</view>
  </view>

  <!-- 今日考勤状态 -->
  <view class="card">
    <view class="card-title">今日考勤</view>
    <view class="attendance-status">
      <view class="status-item">
        <view class="status-label">签到</view>
        <view class="status-value {{todayAttendance.checkInTime ? 'checked' : ''}}">
          {{todayAttendance.checkInTime || '未签到'}}
        </view>
        <view class="status-tag {{todayAttendance.checkInStatus === 0 ? 'status-success' : todayAttendance.checkInStatus === 1 ? 'status-warning' : ''}}">
          {{todayAttendance.checkInStatus === 0 ? '正常' : todayAttendance.checkInStatus === 1 ? '迟到' : ''}}
        </view>
      </view>
      <view class="status-divider"></view>
      <view class="status-item">
        <view class="status-label">签退</view>
        <view class="status-value {{todayAttendance.checkOutTime ? 'checked' : ''}}">
          {{todayAttendance.checkOutTime || '未签退'}}
        </view>
        <view class="status-tag {{todayAttendance.checkOutStatus === 0 ? 'status-success' : todayAttendance.checkOutStatus === 2 ? 'status-warning' : ''}}">
          {{todayAttendance.checkOutStatus === 0 ? '正常' : todayAttendance.checkOutStatus === 2 ? '早退' : ''}}
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="card">
    <view class="card-title">快捷功能</view>
    <view class="quick-menu">
      <view class="menu-item" bindtap="goToCheckin">
        <view class="menu-icon checkin-icon">📍</view>
        <view class="menu-text">签到打卡</view>
      </view>
      <view class="menu-item" bindtap="goToLeave">
        <view class="menu-icon leave-icon">📝</view>
        <view class="menu-text">请假申请</view>
      </view>
      <view class="menu-item" bindtap="goToFieldwork">
        <view class="menu-icon fieldwork-icon">🚗</view>
        <view class="menu-text">外勤报备</view>
      </view>
      <view class="menu-item" bindtap="goToAppeal">
        <view class="menu-icon appeal-icon">📋</view>
        <view class="menu-text">异常申诉</view>
      </view>
      <view class="menu-item" bindtap="goToOvertime">
        <view class="menu-icon overtime-icon">⏱️</view>
        <view class="menu-text">加班申请</view>
      </view>
    </view>
  </view>

  <!-- 本月统计 -->
  <view class="card">
    <view class="card-title">本月统计</view>
    <view class="month-stats">
      <view class="stat-item">
        <view class="stat-value">{{monthStats.normalDays || 0}}</view>
        <view class="stat-label">正常</view>
      </view>
      <view class="stat-item">
        <view class="stat-value warning">{{monthStats.lateDays || 0}}</view>
        <view class="stat-label">迟到</view>
      </view>
      <view class="stat-item">
        <view class="stat-value warning">{{monthStats.earlyDays || 0}}</view>
        <view class="stat-label">早退</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{monthStats.leaveDays || 0}}</view>
        <view class="stat-label">请假</view>
      </view>
      <view class="stat-item">
        <view class="stat-value error">{{monthStats.absentDays || 0}}</view>
        <view class="stat-label">旷工</view>
      </view>
    </view>
  </view>
</view>
