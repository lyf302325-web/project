.container {
  padding: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
  margin-left: 20rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.user-no {
  font-size: 24rpx;
  opacity: 0.9;
}

.month-label {
  font-size: 26rpx;
  opacity: 0.9;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.record-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.record-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.record-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.row-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #999;
}

.row-time {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.row-status {
  font-size: 24rpx;
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.status-success {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-warning {
  background-color: #fff7e6;
  color: #faad14;
}

.record-photo {
  display: flex;
  align-items: center;
  padding: 12rpx 0 12rpx 80rpx;
}

.photo-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e8e8e8;
}

.photo-label {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

