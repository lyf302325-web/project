.container {
  padding: 20rpx;
}

.apply-btn {
  background-color: #1890ff;
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.filter-tabs {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
}

.tab.active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.list-item {
  display: block;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.appeal-date {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.item-content {
  padding: 8rpx 0;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.info-label {
  color: #999;
  width: 160rpx;
}

.info-value {
  color: #333;
  flex: 1;
}

.info-value.reason {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.apply-time {
  font-size: 24rpx;
  color: #999;
}
