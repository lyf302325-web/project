.container {
  padding: 20rpx;
}

.search-bar {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  padding: 12rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.search-btn {
  padding: 12rpx 24rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.add-btn {
  background-color: #1890ff;
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.list-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.employee-avatar {
  width: 80rpx;
  height: 80rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.employee-info {
  flex: 1;
  margin-left: 20rpx;
}

.employee-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.employee-detail {
  font-size: 24rpx;
  color: #999;
}

.divider {
  margin: 0 12rpx;
}

.employee-actions {
  display: flex;
}

.action-btn {
  padding: 12rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  margin-left: 12rpx;
}

.action-btn.edit {
  background-color: #e6f7ff;
  color: #1890ff;
}

.action-btn.delete {
  background-color: #fff2f0;
  color: #ff4d4f;
}
