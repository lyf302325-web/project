.container {
  padding: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  width: 180rpx;
  color: #666;
  font-size: 28rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.form-input.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.arrow {
  color: #999;
  font-size: 24rpx;
}

.btn-group {
  margin-top: 40rpx;
}

.submit-btn {
  background-color: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
}

.reset-pwd-btn {
  background-color: #fff;
  color: #faad14;
  border: 1rpx solid #faad14;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
}
