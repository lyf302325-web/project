<view class="container">
  <view class="card">
    <view class="form-item">
      <view class="form-label">工号</view>
      <input class="form-input" placeholder="请输入工号" value="{{formData.employeeNo}}" bindinput="onInput" data-field="employeeNo" />
    </view>

    <view class="form-item">
      <view class="form-label">姓名</view>
      <input class="form-input" placeholder="请输入姓名" value="{{formData.name}}" bindinput="onInput" data-field="name" />
    </view>

    <view class="form-item">
      <view class="form-label">部门</view>
      <picker mode="selector" range="{{departments}}" range-key="name" bindchange="onDepartmentChange">
        <view class="form-input picker">
          {{formData.departmentName || '请选择部门'}}
          <text class="arrow">▶</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">岗位</view>
      <input class="form-input" placeholder="请输入岗位" value="{{formData.position}}" bindinput="onInput" data-field="position" />
    </view>

    <view class="form-item">
      <view class="form-label">手机号</view>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="onInput" data-field="phone" />
    </view>

    <view class="form-item">
      <view class="form-label">入职日期</view>
      <picker mode="date" value="{{formData.hireDate}}" bindchange="onHireDateChange">
        <view class="form-input picker">
          {{formData.hireDate || '请选择'}}
          <text class="arrow">▶</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">离职日期</view>
      <picker mode="date" value="{{formData.resignDate}}" bindchange="onResignDateChange">
        <view class="form-input picker">
          {{formData.resignDate || '未离职'}}
          <text class="arrow">▶</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">登录账号</view>
      <input class="form-input" placeholder="请输入登录账号" value="{{formData.username}}" bindinput="onInput" data-field="username" />
    </view>

    <view class="form-item" wx:if="{{!isEdit}}">
      <view class="form-label">初始密码</view>
      <input class="form-input" placeholder="请输入初始密码" value="{{formData.password}}" bindinput="onInput" data-field="password" />
    </view>

    <view class="form-item">
      <view class="form-label">角色</view>
      <picker mode="selector" range="{{roles}}" range-key="name" bindchange="onRoleChange">
        <view class="form-input picker">
          {{formData.roleName || '请选择角色'}}
          <text class="arrow">▶</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="btn-group">
    <button class="submit-btn" bindtap="handleSubmit" loading="{{loading}}">{{isEdit ? '保存修改' : '添加员工'}}</button>
    <button class="reset-pwd-btn" wx:if="{{isEdit}}" bindtap="handleResetPassword">重置密码</button>
  </view>
</view>
