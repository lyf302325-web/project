.container {
  padding: 20rpx;
}

.filter-tabs {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  background-color: #fff;
}

.tab.active {
  color: #1890ff;
  background-color: #e6f7ff;
  font-weight: 600;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.filter-input {
  background: #f7f7f7;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
}

.search-btn {
  font-size: 24rpx;
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.export-btn {
  font-size: 24rpx;
  color: #1890ff;
}

.list-item {
  display: block;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.left {
  display: flex;
  align-items: center;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  background-color: #1890ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.meta .name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.meta .sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.item-content .line {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.label {
  color: #999;
  width: 120rpx;
}

.value {
  color: #333;
  flex: 1;
}

.item-actions {
  margin-top: 16rpx;
}

.opinion-input {
  background: #f7f7f7;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.action-btns {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.action-btn.reject {
  background: #fff1f0;
  color: #ff4d4f;
}

.action-btn.approve {
  background: #f6ffed;
  color: #52c41a;
}
