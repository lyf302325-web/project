.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx 20rpx;
}

.item {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item:last-child {
  border-bottom: none;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.sub {
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.btn {
  border-radius: 10rpx;
}

.pass {
  background: #52c41a;
  color: #fff;
}

.reject {
  background: #ff4d4f;
  color: #fff;
}

.empty {
  padding: 160rpx 0;
  text-align: center;
}

.empty-text {
  color: #999;
  font-size: 26rpx;
}

.refresh {
  margin-top: 30rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  width: 260rpx;
}
