.container {
  padding: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item.switch-item {
  justify-content: space-between;
}

.form-info {
  flex: 1;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.form-desc {
  font-size: 24rpx;
  color: #999;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.form-input.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.arrow {
  color: #999;
  font-size: 24rpx;
}

.submit-btn {
  margin-top: 40rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
}
