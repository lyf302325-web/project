.container {
  padding: 20rpx;
}

.filter-card {
  margin-bottom: 20rpx;
}

.filter-row {
  display: flex;
  align-items: center;
}

.filter-item {
  flex: 1;
  margin-right: 16rpx;
}

.filter-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.arrow {
  color: #999;
  font-size: 24rpx;
}

.search-btn {
  padding: 16rpx 24rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.list-item {
  display: block;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.log-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.log-time {
  font-size: 24rpx;
  color: #999;
}

.log-content {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.log-action {
  font-size: 28rpx;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.log-detail {
  font-size: 26rpx;
  color: #666;
}

.log-ip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}
