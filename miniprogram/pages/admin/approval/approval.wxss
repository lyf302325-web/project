.container {
  padding: 20rpx;
}

.filter-tabs {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
}

.tab.active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.list-item {
  display: block;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.applicant-info {
  display: flex;
  align-items: center;
}

.applicant-avatar {
  width: 64rpx;
  height: 64rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.applicant-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.item-content {
  padding: 8rpx 0;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.info-label {
  color: #999;
  width: 160rpx;
}

.info-value {
  color: #333;
  flex: 1;
}

.item-actions {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.opinion-input {
  width: 100%;
  padding: 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  width: 0;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 26rpx;
  margin: 0;
  line-height: 1.5;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-btn.approve {
  background-color: #52c41a;
  color: #fff;
}

.action-btn.reject {
  background-color: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

.item-result {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.result-label {
  font-size: 26rpx;
  color: #999;
}

.result-value {
  font-size: 26rpx;
  color: #666;
}
