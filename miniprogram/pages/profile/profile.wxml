<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar">{{userInfo.name ? userInfo.name[0] : '员'}}</view>
    <view class="user-info">
      <view class="user-name">{{userInfo.name || '员工'}}</view>
      <view class="user-dept">{{userInfo.departmentName || '未分配部门'}}</view>
    </view>
  </view>

  <!-- 个人信息 -->
  <view class="card">
    <view class="card-title">个人信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">工号</text>
        <text class="info-value">{{userInfo.employeeNo || '--'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">姓名</text>
        <text class="info-value">{{userInfo.name || '--'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">部门</text>
        <text class="info-value">{{userInfo.departmentName || '--'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">岗位</text>
        <text class="info-value">{{userInfo.position || '--'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">手机号</text>
        <text class="info-value">{{userInfo.phone || '--'}}</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card">
    <view class="menu-list">
      <view class="menu-item" bindtap="goToChangePassword">
        <view class="menu-icon">🔐</view>
        <view class="menu-text">修改密码</view>
        <view class="menu-arrow">▶</view>
      </view>
      <view class="menu-item" bindtap="goToLeaveBalance">
        <view class="menu-icon">🧾</view>
        <view class="menu-text">请假余额</view>
        <view class="menu-arrow">▶</view>
      </view>
      <view class="menu-item" bindtap="unbindWx">
        <view class="menu-icon">📱</view>
        <view class="menu-text">解除微信绑定</view>
        <view class="menu-arrow">▶</view>
      </view>
      <view class="menu-item" wx:if="{{isAdmin}}" bindtap="goToAdmin">
        <view class="menu-icon">⚙️</view>
        <view class="menu-text">管理后台</view>
        <view class="menu-arrow">▶</view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="logout-btn" bindtap="handleLogout">退出登录</button>
</view>

<!-- 修改密码弹窗 -->
<view class="modal" wx:if="{{showPasswordModal}}">
  <view class="modal-mask" bindtap="closePasswordModal"></view>
  <view class="modal-content">
    <view class="modal-title">修改密码</view>
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">原密码</text>
        <input class="form-input" type="password" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPasswordInput" />
      </view>
      <view class="form-item">
        <text class="form-label">新密码</text>
        <input class="form-input" type="password" placeholder="请输入新密码" value="{{newPassword}}" bindinput="onNewPasswordInput" />
      </view>
      <view class="form-item">
        <text class="form-label">确认密码</text>
        <input class="form-input" type="password" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closePasswordModal">取消</button>
      <button class="modal-btn confirm" bindtap="submitChangePassword">确定</button>
    </view>
  </view>
</view>
