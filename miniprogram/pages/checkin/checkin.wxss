.container {
  padding: 20rpx;
}

.time-card {
  text-align: center;
  padding: 40rpx 0;
}

.current-time {
  font-size: 80rpx;
  font-weight: bold;
  color: #333;
}

.current-date {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}

.checkin-area {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.checkin-btn {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.3);
}

.checkin-btn.active {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
}

.checkin-btn.disabled {
  background: #d9d9d9;
}

.btn-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.btn-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
}

.location-info {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.location-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.location-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.location-status {
  text-align: center;
  padding: 12rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  margin: 16rpx 0;
}

.location-status.valid {
  background-color: #f6ffed;
  color: #52c41a;
}

.location-status.invalid {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.refresh-btn {
  background-color: #fff;
  color: #1890ff;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
}

.record-list {
  padding: 16rpx 0;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-type {
  width: 100rpx;
  font-size: 28rpx;
  color: #666;
}

.record-time {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.record-status {
  font-size: 24rpx;
}

.photo-tip {
  text-align: center;
  padding: 16rpx 24rpx;
  background-color: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #d48806;
}

.photo-preview {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.preview-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx solid #1890ff;
}
