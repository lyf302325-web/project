.container {
  padding: 20rpx;
}

.apply-btn {
  background-color: #1890ff;
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 32rpx;
}

.filter-tabs {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #666;
}

.tab.active {
  color: #1890ff;
  background-color: #e6f7ff;
  font-weight: 600;
}

.list-item {
  display: block;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.type {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.info-label {
  width: 120rpx;
  color: #999;
}

.info-value {
  flex: 1;
  color: #333;
}

.reason {
  color: #666;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.apply-time {
  font-size: 24rpx;
  color: #999;
}

.cancel-btn {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
}
