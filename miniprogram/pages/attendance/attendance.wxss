.container {
  padding: 20rpx;
}

.month-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.arrow {
  padding: 20rpx;
  color: #1890ff;
  font-size: 28rpx;
}

.month-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin: 0 40rpx;
}

.stats-card {
  margin-bottom: 20rpx;
}

.stat-row {
  display: flex;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-value.success {
  color: #52c41a;
}

.stat-value.warning {
  color: #faad14;
}

.stat-value.error {
  color: #ff4d4f;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.export-btn {
  font-size: 26rpx;
  color: #1890ff;
  padding: 8rpx 16rpx;
  border: 1rpx solid #1890ff;
  border-radius: 6rpx;
}

.record-list {
  margin-top: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  width: 100rpx;
  text-align: center;
}

.date-day {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.date-week {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.record-detail {
  flex: 1;
  padding: 0 20rpx;
}

.time-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.time-row:last-child {
  margin-bottom: 0;
}

.time-label {
  font-size: 26rpx;
  color: #999;
  width: 80rpx;
}

.time-value {
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
}

.record-status {
  width: 100rpx;
  text-align: center;
}

.overall-status {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.overall-status.normal {
  background-color: #f6ffed;
  color: #52c41a;
}

.overall-status.abnormal {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.overall-status.leave {
  background-color: #e6f7ff;
  color: #1890ff;
}
